import { useEffect, useMemo, useState } from "react";
import { View, Text, TextInput, Pressable, ScrollView, Alert } from "react-native";
import { Stack } from "expo-router";
import * as SQLite from "expo-sqlite";
import { COLORS, SPACING, TEXT } from "../../constants/theme";

type BhhReviewRow = {
  id: string;
  whiskeyId: string | null;
  whiskeyName: string;
  reviewer: string;
  score: number;
  reviewedAt: string | null;
  youtubeUrl: string | null;
  title: string | null;
};

function slugifyLocal(input: string) {
  return (input ?? "")
    .toLowerCase()
    .trim()
    .replace(/['"]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

/**
 * Extract a likely bottle name from a YouTube title.
 * This is heuristic-based but works well for typical review titles.
 */
function extractWhiskeyNameFromTitle(titleRaw: string): string | null {
  if (!titleRaw) return null;

  let t = titleRaw.trim();

  // Drop channel suffixes
  t = t.replace(/\s*[-–—]\s*Buffalo Happy Hour\s*$/i, "");
  t = t.replace(/\s*[-–—]\s*BHH\s*$/i, "");

  // Common prefixes
  t = t.replace(/^wednesday\s+whiskey\s+review\s*:\s*/i, "");
  t = t.replace(/^whiskey\s+review\s*:\s*/i, "");
  t = t.replace(/^review\s*:\s*/i, "");

  // If it's a question title like "Is X the best ...?"
  // Try to grab the phrase after "Is " and before " the "
  const q1 = t.match(/^is\s+(.+?)\s+the\s+/i);
  if (q1?.[1]) {
    const candidate = q1[1].trim();
    if (candidate.length >= 4 && candidate.length <= 60) return candidate;
  }

  // If it's "Is X ...?" but no "the", take up to '?'.
  const q2 = t.match(/^is\s+(.+?)\?/i);
  if (q2?.[1]) {
    const candidate = q2[1].trim();
    if (candidate.length >= 4 && candidate.length <= 60) return candidate;
  }

  // If there's a colon, take content after it (often "Series: Bottle Name")
  if (t.includes(":")) {
    const after = t.split(":").slice(1).join(":").trim();
    if (after.length >= 4) t = after;
  }

  // If there's " - " and the right side is channel/episode, take left
  if (t.includes(" - ")) {
    const left = t.split(" - ")[0].trim();
    if (left.length >= 4) t = left;
  }

  // Remove trailing hype phrases / punctuation
  t = t.replace(/[!?]+$/g, "").trim();

  // If it still looks like a full sentence, shorten at common separators
  // (e.g. "Laphroaig 2024 Cairdeas | Full Review" -> "Laphroaig 2024 Cairdeas")
  t = t.split("|")[0].trim();
  t = t.split("•")[0].trim();
  t = t.split("~")[0].trim();

  // Remove super-common fluff endings
  t = t.replace(/\s+(review|full review|reviewed|tasting)\s*$/i, "").trim();

  // Sanity checks
  if (t.length < 4) return null;
  if (t.length > 70) return null;

  // If it contains too many words like a sentence, reject (we want bottle-like names)
  const words = t.split(/\s+/).filter(Boolean);
  if (words.length > 10) return null;

  return t;
}

async function openDbWithRequiredTables() {
  const candidates = [
    "whiskeyappbeta.db",
    "WhiskeyAppBeta.db",
    "whiskey.db",
    "app.db",
    "database.db",
    "db.db",
    "default.db",
  ];

  for (const name of candidates) {
    try {
      const db = SQLite.openDatabaseSync(name);
      const hit = await db.getFirstAsync<{ name: string }>(
        "SELECT name FROM sqlite_master WHERE type='table' AND name='bhh_reviews' LIMIT 1;"
      );
      const hit2 = await db.getFirstAsync<{ name: string }>(
        "SELECT name FROM sqlite_master WHERE type='table' AND name='tastings' LIMIT 1;"
      );
      if (hit?.name === "bhh_reviews" && hit2?.name === "tastings") {
        return { db, name };
      }
    } catch {}
  }

  const db = SQLite.openDatabaseSync("default.db");
  return { db, name: "default.db" };
}

export default function DbInspectorScreen() {
  const [dbName, setDbName] = useState<string>("(opening...)");
  const [term, setTerm] = useState("balvenie");
  const [rows, setRows] = useState<BhhReviewRow[]>([]);
  const [loading, setLoading] = useState(false);

  const canSearch = useMemo(() => term.trim().length >= 2, [term]);

  async function runSearch() {
    if (!canSearch) {
      Alert.alert("Search term too short", "Type at least 2 characters.");
      return;
    }

    setLoading(true);
    try {
      const { db, name } = await openDbWithRequiredTables();
      setDbName(name);

      const like = `%${term.trim()}%`;
      const r = await db.getAllAsync<BhhReviewRow[]>(
        `SELECT id, whiskeyId, whiskeyName, reviewer, score, reviewedAt, youtubeUrl, title
         FROM bhh_reviews
         WHERE LOWER(whiskeyName) LIKE LOWER(?)
            OR (title IS NOT NULL AND LOWER(title) LIKE LOWER(?))
         ORDER BY reviewedAt DESC
         LIMIT 50`,
        [like, like]
      );

      setRows((r as any) ?? []);
    } catch (e: any) {
      console.log("DB search failed:", e);
      Alert.alert("DB search failed", e?.message ?? String(e));
    } finally {
      setLoading(false);
    }
  }

  async function normalizeBhhWhiskeyIds() {
    Alert.alert(
      "Normalize BHH IDs",
      "This sets bhh_reviews.whiskeyId = slugify(whiskeyName). Continue?",
      [
        { text: "Cancel", style: "cancel" },
        {
          text: "Normalize",
          style: "destructive",
          onPress: async () => {
            setLoading(true);
            try {
              const { db, name } = await openDbWithRequiredTables();
              setDbName(name);

              const all = await db.getAllAsync<{ id: string; whiskeyName: string }[]>(
                `SELECT id, whiskeyName
                 FROM bhh_reviews
                 WHERE whiskeyName IS NOT NULL AND TRIM(whiskeyName) != ''`
              );

              let changed = 0;
              await db.execAsync("BEGIN;");
              for (const item of (all as any) ?? []) {
                const newId = slugifyLocal(item.whiskeyName);
                if (!newId) continue;
                await db.runAsync(`UPDATE bhh_reviews SET whiskeyId = ? WHERE id = ?`, [
                  newId,
                  item.id,
                ]);
                changed++;
              }
              await db.execAsync("COMMIT;");

              Alert.alert("Done", `Normalized ${changed} rows.`);
            } catch (e: any) {
              try {
                const { db } = await openDbWithRequiredTables();
                await db.execAsync("ROLLBACK;");
              } catch {}
              console.log("Normalize failed:", e);
              Alert.alert("Normalize failed", e?.message ?? String(e));
            } finally {
              setLoading(false);
            }
          },
        },
      ]
    );
  }

  async function extractNamesFromTitles() {
    Alert.alert(
      "Extract whiskey names from titles",
      "This will try to replace whiskeyName with a cleaned bottle name derived from title, then update whiskeyId accordingly. Continue?",
      [
        { text: "Cancel", style: "cancel" },
        {
          text: "Extract",
          style: "destructive",
          onPress: async () => {
            setLoading(true);
            try {
              const { db, name } = await openDbWithRequiredTables();
              setDbName(name);

              const all = await db.getAllAsync<{ id: string; whiskeyName: string; title: string | null }[]>(
                `SELECT id, whiskeyName, title
                 FROM bhh_reviews`
              );

              let updated = 0;
              let skipped = 0;

              await db.execAsync("BEGIN;");

              for (const item of (all as any) ?? []) {
                const title = item.title ?? "";
                const extracted = extractWhiskeyNameFromTitle(title);

                if (!extracted) {
                  skipped++;
                  continue;
                }

                // Only overwrite if current whiskeyName looks like a title/sentence:
                // - very long OR
                // - contains '?' OR
                // - starts with "Is " OR
                // - equals the title exactly
                const wn = (item.whiskeyName ?? "").trim();
                const wnLooksBad =
                  wn.length > 55 ||
                  wn.includes("?") ||
                  /^is\s+/i.test(wn) ||
                  (title && wn === title.trim());

                if (!wnLooksBad) {
                  skipped++;
                  continue;
                }

                const newId = slugifyLocal(extracted);

                await db.runAsync(
                  `UPDATE bhh_reviews
                   SET whiskeyName = ?, whiskeyId = ?
                   WHERE id = ?`,
                  [extracted, newId, item.id]
                );
                updated++;
              }

              await db.execAsync("COMMIT;");

              Alert.alert("Done", `Updated ${updated} rows. Skipped ${skipped}.`);
            } catch (e: any) {
              try {
                const { db } = await openDbWithRequiredTables();
                await db.execAsync("ROLLBACK;");
              } catch {}
              console.log("Extract failed:", e);
              Alert.alert("Extract failed", e?.message ?? String(e));
            } finally {
              setLoading(false);
            }
          },
        },
      ]
    );
  }

  useEffect(() => {
    runSearch();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  return (
    <ScrollView style={{ flex: 1, backgroundColor: COLORS.bg }}>
      <Stack.Screen options={{ title: "DB Inspector" }} />

      <View style={{ padding: SPACING.md, gap: SPACING.md }}>
        <Text style={{ fontSize: TEXT.h1, fontWeight: "900", color: COLORS.ink }}>
          DB Inspector
        </Text>

        <Text style={{ color: COLORS.ink, opacity: 0.75 }}>
          Active DB: <Text style={{ fontWeight: "900" }}>{dbName}</Text>
        </Text>

        <View
          style={{
            backgroundColor: COLORS.card,
            borderRadius: 16,
            padding: SPACING.md,
            borderWidth: 1,
            borderColor: COLORS.border,
            gap: SPACING.sm,
          }}
        >
          <Text style={{ color: COLORS.ink, fontWeight: "900" }}>
            Search bhh_reviews (name or title)
          </Text>

          <TextInput
            value={term}
            onChangeText={setTerm}
            placeholder="type a brand/bottle name"
            placeholderTextColor={COLORS.muted}
            autoCapitalize="none"
            style={{
              borderWidth: 1,
              borderColor: COLORS.border,
              borderRadius: 14,
              padding: 12,
              color: COLORS.ink,
              backgroundColor: COLORS.bg,
            }}
          />

          <Pressable
            onPress={runSearch}
            disabled={!canSearch || loading}
            style={{
              paddingVertical: 12,
              borderRadius: 14,
              alignItems: "center",
              backgroundColor: !canSearch || loading ? COLORS.border : COLORS.primary,
            }}
          >
            <Text style={{ color: COLORS.bg, fontWeight: "900" }}>
              {loading ? "Working..." : "Search"}
            </Text>
          </Pressable>

          <View style={{ flexDirection: "row", gap: 10 }}>
            <Pressable
              onPress={extractNamesFromTitles}
              disabled={loading}
              style={{
                flex: 1,
                paddingVertical: 12,
                borderRadius: 14,
                alignItems: "center",
                backgroundColor: loading ? COLORS.border : COLORS.card,
                borderWidth: 1,
                borderColor: COLORS.border,
              }}
            >
              <Text style={{ color: COLORS.ink, fontWeight: "900" }}>
                Extract Names
              </Text>
            </Pressable>

            <Pressable
              onPress={normalizeBhhWhiskeyIds}
              disabled={loading}
              style={{
                flex: 1,
                paddingVertical: 12,
                borderRadius: 14,
                alignItems: "center",
                backgroundColor: loading ? COLORS.border : COLORS.card,
                borderWidth: 1,
                borderColor: COLORS.border,
              }}
            >
              <Text style={{ color: COLORS.ink, fontWeight: "900" }}>
                Normalize IDs
              </Text>
            </Pressable>
          </View>

          <Text style={{ color: COLORS.ink, opacity: 0.65, fontSize: 12 }}>
            Recommended order: 1) Extract Names  2) Normalize IDs
          </Text>
        </View>

        <Text style={{ color: COLORS.ink, opacity: 0.8 }}>
          Results: <Text style={{ fontWeight: "900" }}>{rows.length}</Text>
        </Text>

        {rows.map((r) => (
          <View
            key={r.id}
            style={{
              backgroundColor: COLORS.card,
              borderRadius: 16,
              padding: SPACING.md,
              borderWidth: 1,
              borderColor: COLORS.border,
              gap: 6,
            }}
          >
            <Text style={{ color: COLORS.ink, fontWeight: "900" }}>
              whiskeyName: {r.whiskeyName}
            </Text>
            <Text style={{ color: COLORS.ink, opacity: 0.75 }}>
              whiskeyId: <Text style={{ fontWeight: "900" }}>{r.whiskeyId ?? "(null)"}</Text>
            </Text>
            <Text style={{ color: COLORS.ink, opacity: 0.75 }}>
              score: <Text style={{ fontWeight: "900" }}>{r.score}</Text>
            </Text>
            {!!r.title && (
              <Text style={{ color: COLORS.ink, opacity: 0.75 }}>
                title: <Text style={{ fontWeight: "700" }}>{r.title}</Text>
              </Text>
            )}
          </View>
        ))}
      </View>
    </ScrollView>
  );
}
