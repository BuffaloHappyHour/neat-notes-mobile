import { useMemo, useState } from "react";
import { View, Text, TextInput, Pressable, Alert, ScrollView } from "react-native";
import { router } from "expo-router";
import { COLORS, SPACING, TEXT } from "../../constants/theme";
import { WHISKEYS } from "../../lib/whiskeys";

function slugifyLocal(input: string) {
  return (input ?? "")
    .toLowerCase()
    .trim()
    .replace(/['"]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

/**
 * Attempt to pull names from data/bhhScoreUpdates.ts (if present).
 * This avoids DB access (no execAsync), and still uses your YouTube-derived dataset.
 */
function getBhhNamesBestEffort(): string[] {
  try {
    // eslint-disable-next-line @typescript-eslint/no-var-requires
    const mod = require("../../data/bhhScoreUpdates");
    const arr = mod?.BHH_SCORE_UPDATES ?? mod?.default ?? mod;

    if (!Array.isArray(arr)) return [];

    const out: string[] = [];
    for (const item of arr) {
      if (!item) continue;

      // common possibilities
      const wn =
        (typeof item.whiskeyName === "string" && item.whiskeyName) ||
        (typeof item.name === "string" && item.name) ||
        "";

      if (wn) {
        out.push(wn);
        continue;
      }

      // fallback: extract something from title like "Wednesday WHISKEY Review: Balvenie 14 Year ... - Buffalo Happy Hour"
      const title = typeof item.title === "string" ? item.title : "";
      if (title) {
        // take substring after ":" if present, else before "-"
        const afterColon = title.includes(":") ? title.split(":").slice(1).join(":").trim() : title.trim();
        const beforeDash = afterColon.includes(" - ") ? afterColon.split(" - ")[0].trim() : afterColon;
        if (beforeDash && beforeDash.length >= 3) out.push(beforeDash);
      }
    }

    return out;
  } catch {
    return [];
  }
}

export default function LogTab() {
  const [query, setQuery] = useState("");

  const allNames = useMemo(() => {
    const fromWhiskeys = WHISKEYS.map((w) => w.name).filter(Boolean);
    const fromBhh = getBhhNamesBestEffort();

    // de-dupe (case-insensitive)
    const seen = new Set<string>();
    const merged: string[] = [];
    for (const n of [...fromBhh, ...fromWhiskeys]) {
      const key = n.trim().toLowerCase();
      if (!key) continue;
      if (seen.has(key)) continue;
      seen.add(key);
      merged.push(n.trim());
    }
    return merged;
  }, []);

  const suggestions = useMemo(() => {
    const q = query.trim().toLowerCase();
    if (q.length < 2) return [];
    return allNames
      .filter((n) => n.toLowerCase().includes(q))
      .slice(0, 10);
  }, [query, allNames]);

  const canGo = useMemo(() => query.trim().length >= 2, [query]);

  function onPick(name: string) {
    setQuery(name);
  }

  function onFindWhiskey() {
    const name = query.trim();
    if (!name || name.length < 2) {
      Alert.alert("Type a whiskey", "Please enter at least 2 characters.");
      return;
    }
    const id = slugifyLocal(name);

    router.push({
      pathname: `/whiskey/${id}`,
      params: { name },
    });
  }

  return (
    <View
      style={{
        flex: 1,
        backgroundColor: COLORS.bg,
        padding: SPACING.md,
        gap: SPACING.md,
      }}
    >
      <Text style={{ fontSize: TEXT.h1, fontWeight: "800", color: COLORS.ink }}>
        Log
      </Text>

      <Text style={{ color: COLORS.ink, opacity: 0.8 }}>
        Start typing a whiskey. We’ll suggest bottles from our BHH/YouTube dataset (plus the seeded list). Then tap Find Whiskey to view the whiskey page and log your tasting.
      </Text>

      <View
        style={{
          borderWidth: 1,
          borderColor: COLORS.border,
          backgroundColor: COLORS.card,
          borderRadius: 16,
          padding: SPACING.md,
          gap: SPACING.sm,
        }}
      >
        <Text style={{ fontWeight: "800", color: COLORS.ink }}>
          Whiskey name
        </Text>

        <TextInput
          value={query}
          onChangeText={setQuery}
          placeholder="e.g., Balvenie 14 Caribbean Cask"
          placeholderTextColor={COLORS.muted}
          autoCorrect={false}
          autoCapitalize="words"
          style={{
            borderWidth: 1,
            borderColor: COLORS.border,
            borderRadius: 14,
            padding: 12,
            color: COLORS.ink,
            backgroundColor: COLORS.bg,
          }}
        />

        {suggestions.length > 0 ? (
          <ScrollView
            style={{
              maxHeight: 220,
              borderWidth: 1,
              borderColor: COLORS.border,
              borderRadius: 14,
              overflow: "hidden",
              backgroundColor: COLORS.bg,
            }}
          >
            {suggestions.map((s) => (
              <Pressable
                key={s}
                onPress={() => onPick(s)}
                style={({ pressed }) => ({
                  paddingVertical: 12,
                  paddingHorizontal: 12,
                  borderBottomWidth: 1,
                  borderBottomColor: COLORS.border,
                  opacity: pressed ? 0.7 : 1,
                })}
              >
                <Text style={{ color: COLORS.ink }}>{s}</Text>
              </Pressable>
            ))}
          </ScrollView>
        ) : null}

        <Pressable
          onPress={onFindWhiskey}
          disabled={!canGo}
          style={({ pressed }) => ({
            marginTop: SPACING.xs,
            borderRadius: 16,
            paddingVertical: 14,
            alignItems: "center",
            backgroundColor: canGo ? COLORS.primary : COLORS.border,
            opacity: pressed ? 0.85 : 1,
          })}
        >
          <Text style={{ color: COLORS.bg, fontWeight: "900", fontSize: 16 }}>
            Find Whiskey
          </Text>
        </Pressable>
      </View>
    </View>
  );
}
